{
	"mcpServers": {
		"aws-billing-cost-management-mcp-server": {
			"command": "uvx",
			"args": ["awslabs.billing-cost-management-mcp-server@latest"],
			"env": {
			"FASTMCP_LOG_LEVEL": "ERROR",
			"AWS_PROFILE": "${AWS_PROFILE:-default}",
			"AWS_REGION": "${AWS_REGION:-us-east-1}"
			},
			"disabled": false,
			"autoApprove": []
		}
	}
}
